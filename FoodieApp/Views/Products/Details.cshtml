@model FoodieApp.Models.Product

@{
    ViewData["Title"] = "Détails Produit";
}

<section class="food_section layout_padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-9">
                <div class="card border-0 shadow-lg rounded-lg overflow-hidden">
                     <div class="card-header bg-warning text-white py-4 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 font-weight-light text-white">Détails du Produit</h4>
                        <a asp-action="Index" class="btn btn-sm btn-outline-light rounded-pill"><i class="fa fa-arrow-left"></i> Retour</a>
                    </div>
                    <div class="card-body p-0">
                        <div class="row no-gutters">
                            <div class="col-md-5 bg-light d-flex align-items-center justify-content-center p-5">
                                <img src="@(Model.ImageUrl ?? "/images/f1.png")" alt="@Model.Name" class="img-fluid rounded shadow-sm" style="max-height: 300px;">
                            </div>
                            <div class="col-md-7 p-5">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h2 class="font-weight-bold mb-0">@Model.Name</h2>
                                    <span class="badge badge-dark p-2">@(Model.Category?.Name ?? "Non classé")</span>
                                </div>
                                <h4 class="text-warning font-weight-bold mb-4">@Model.Price €</h4>
                                
                                <h6 class="text-uppercase text-muted small font-weight-bold">Description</h6>
                                <p class="text-muted mb-4">@Model.Description</p>

                                <div class="row mb-4">
                                    <div class="col-6">
                                        <h6 class="text-uppercase text-muted small font-weight-bold">Stock</h6>
                                        <p class="font-weight-bold">@Model.Quantity unités</p>
                                    </div>
                                    <div class="col-6">
                                        <h6 class="text-uppercase text-muted small font-weight-bold">Statut</h6>
                                        <p>
                                            @if (Model.IsActive == true)
                                            {
                                                <span class="text-success font-weight-bold"><i class="fa fa-check-circle"></i> Actif</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger font-weight-bold"><i class="fa fa-times-circle"></i> Inactif</span>
                                            }
                                        </p>
                                    </div>
                                </div>
                                
                                <div class="row mb-4">
                                     <div class="col-12">
                                        <h6 class="text-uppercase text-muted small font-weight-bold">Date de création</h6>
                                        <p class="text-small text-muted">@Model.CreateDate</p>
                                     </div>
                                </div>

                                <div class="d-flex mt-5">
                                    <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-warning text-white rounded-pill px-4 shadow-sm mr-3 font-weight-bold">
                                        <i class="fa fa-pencil mr-2"></i> Modifier
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@Model.ProductId" class="btn btn-outline-danger rounded-pill px-4 shadow-sm font-weight-bold">
                                        <i class="fa fa-trash mr-2"></i> Supprimer
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
