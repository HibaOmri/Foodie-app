@model IEnumerable<FoodieApp.Models.Product>
@{
    ViewData["Title"] = "Home";
}

@section HeroSection {
    <section class="slider_section ">
        <div id="customCarousel1" class="carousel slide" data-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <div class="container ">
                        <div class="row">
                            <div class="col-md-7 col-lg-6 ">
                                <div class="detail-box">
                                    <h1>Fast Food Restaurant</h1>
                                    <p>
                                        Découvrez nos recettes uniques préparées avec des ingrédients frais. Une expérience culinaire inoubliable vous attend.
                                    </p>
                                    <div class="btn-box">
                                        <a href="#menu-section" class="btn1">Commander Maintenant</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <div class="container ">
                        <div class="row">
                            <div class="col-md-7 col-lg-6 ">
                                <div class="detail-box">
                                    <h1>Plats Délicieux</h1>
                                    <p>
                                        Des burgers savoureux, des pizzas croustillantes et bien plus encore. Commandez en ligne dès aujourd'hui !
                                    </p>
                                    <div class="btn-box">
                                        <a asp-action="Menu" class="btn1">Voir le Menu</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="container">
                <ol class="carousel-indicators">
                    <li data-target="#customCarousel1" data-slide-to="0" class="active"></li>
                    <li data-target="#customCarousel1" data-slide-to="1"></li>
                </ol>
            </div>
        </div>
    </section>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa fa-check-circle"></i> <strong>Succès !</strong> @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    </div>
}

<section class="offer_section layout_padding-bottom">
    <div class="offer_container">
        <div class="container ">
            <div class="row">

                <div class="col-md-6">
                    <div class="box ">
                        <div class="img-box">
                            <img src="~/images/o1.jpg" alt="">
                        </div>
                        <div class="detail-box">
                            <h5>Jeudis Gourmands</h5>
                            <h6><span>20%</span> de réduction</h6>

                            <a asp-controller="Cart" asp-action="Add" asp-route-id="1" class="add-to-cart-link">
                                Commander (9.60€)
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="box ">
                        <div class="img-box">
                            <img src="~/images/o2.jpg" alt="">
                        </div>
                        <div class="detail-box">
                            <h5>Journée Pizza</h5>
                            <h6><span>15%</span> de réduction</h6>

                            <a asp-controller="Cart" asp-action="Add" asp-route-id="2" class="add-to-cart-link">
                                Commander (11.90€)
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<section class="food_section layout_padding-bottom" id="menu-section">
    <div class="container">
        <div class="heading_container heading_center">
            <h2>Notre Menu</h2>
        </div>

        <ul class="filters_menu">
            <li class="active" data-filter="*">Tout</li>
            <li data-filter=".Burger">Burger</li>
            <li data-filter=".Pizza">Pizza</li>
            <li data-filter=".Pâtes">Pâtes</li>
            <li data-filter=".Frites">Frites</li>
        </ul>

        <div class="filters-content">
            <div class="row grid">
                @foreach (var item in Model)
                {
                    <div class="col-sm-6 col-lg-4 all @(item.Category?.Name ?? "Autre")">
                        <div class="box">
                            <div>
                                <div class="img-box">
                                    <img src="@(item.ImageUrl ?? "/images/f1.png")" alt="@item.Name">
                                </div>
                                <div class="detail-box">
                                    <h5>@item.Name</h5>
                                    <p>@item.Description</p>
                                    <div class="options">
                                        <h6>@item.Price €</h6>

                                        <a asp-controller="Cart" asp-action="Add" asp-route-id="@item.ProductId" class="add-to-cart-link">
                                            <svg version="1.1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" x="0px" y="0px" viewBox="0 0 456.029 456.029" style="enable-background:new 0 0 456.029 456.029;" xml:space="preserve">
                                            <g><g><path d="M345.6,338.862c-29.184,0-53.248,23.552-53.248,53.248c0,29.184,23.552,53.248,53.248,53.248c29.184,0,53.248-23.552,53.248-53.248C398.336,362.926,374.784,338.862,345.6,338.862z" /></g></g>
                                            <g><g><path d="M439.296,84.91c-1.024,0-2.56-0.512-4.096-0.512H112.64l-5.12-34.304C104.448,27.566,84.992,10.67,61.952,10.67H20.48C9.216,10.67,0,19.886,0,31.15c0,11.264,9.216,20.48,20.48,20.48h41.472c2.56,0,4.608,2.048,5.12,4.608l31.744,216.064c4.096,27.136,27.648,47.616,55.296,47.616h212.992c26.624,0,49.664-18.944,55.296-45.056l33.28-166.4C457.728,97.71,450.56,86.958,439.296,84.91z" /></g></g>
                                            <g><g><path d="M215.04,389.55c-1.024-28.16-24.576-50.688-52.736-50.688c-29.696,1.536-52.224,26.112-51.2,55.296c1.024,28.16,24.064,50.688,52.224,50.688h1.024C193.536,443.31,216.576,418.734,215.04,389.55z" /></g></g>
                                                </svg>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="btn-box">
            <a asp-controller="Home" asp-action="Menu">Voir Plus</a>
        </div>
    </div>
</section>

<section class="about_section layout_padding">
    <div class="container  ">
        <div class="row">
            <div class="col-md-6 ">
                <div class="img-box">
                    <img src="~/images/about-img.png" alt="">
                </div>
            </div>
            <div class="col-md-6">
                <div class="detail-box">
                    <div class="heading_container">
                        <h2>Bienvenue chez Foodie</h2>
                    </div>
                    <p>
                        Nous sommes un restaurant passionné par la bonne cuisine.
                        Nos chefs utilisent des ingrédients frais et de qualité pour vous préparer
                        les meilleurs burgers et pizzas de la ville. Venez goûter la différence !
                    </p>
                    
                </div>
            </div>
        </div>
    </div>
</section>

<section class="book_section layout_padding">
    <div class="container">
        <div class="heading_container">
            <h2>Réserver une Table</h2>
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="form_container">
                    @if (TempData["BookingSuccess"] != null)
                    {
                        <div class="alert alert-success text-center shadow-sm">
                            <i class="fa fa-check-circle mr-2"></i> <strong>@TempData["BookingSuccess"]</strong>
                        </div>
                    }
                    <form asp-controller="Home" asp-action="BookTable" method="post">
                        <div class="form-group mb-4">
                            <label class="font-weight-bold text-muted small text-uppercase">Votre Nom</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0 shadow-sm" name="Name" placeholder="Ex: Jean Dupont" required />
                        </div>
                        <div class="form-group mb-4">
                            <label class="font-weight-bold text-muted small text-uppercase">Téléphone</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0 shadow-sm" name="Phone" placeholder="Ex: 06 12 34 56 78" required />
                        </div>
                        <div class="form-group mb-4">
                             <label class="font-weight-bold text-muted small text-uppercase">Email</label>
                            <input type="email" class="form-control form-control-lg bg-light border-0 shadow-sm" name="Email" placeholder="nom@exemple.com" />
                        </div>
                        <div class="form-group mb-4">
                            <label class="font-weight-bold text-muted small text-uppercase">Nombre de personnes</label>
                            <select class="form-control form-control-lg bg-light border-0 shadow-sm nice-select wide" name="GuestCount">
                                <option value="" disabled selected>Combien ?</option>
                                <option value="2">2 Personnes</option>
                                <option value="3">3 Personnes</option>
                                <option value="4">4 Personnes</option>
                                <option value="5">5 Personnes</option>
                                <option value="6">6 Personnes</option>
                                <option value="8">8 Personnes</option>
                                <option value="10">10+ Personnes</option>
                            </select>
                        </div>
                        <div class="form-group mb-4">
                            <label class="font-weight-bold text-muted small text-uppercase">Date & Heure</label>
                            <input type="datetime-local" class="form-control form-control-lg bg-light border-0 shadow-sm" name="BookingDate" required>
                        </div>
                        <div class="btn_box mt-5">
                            <button type="submit" class="w-100 rounded-pill shadow-lg font-weight-bold py-3 text-uppercase">
                                Confirmer la Réservation
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-md-6">
                <div class="map_container ">
                    <div id="googleMap"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="client_section layout_padding-bottom">
    <div class="container">
        <div class="heading_container heading_center psudo_white_primary mb_45">
            <h2>Ce que disent nos clients</h2>
        </div>
        <div class="carousel-wrap row ">
            <div class="owl-carousel client_owl-carousel">
                <div class="item">
                    <div class="box">
                        <div class="detail-box">
                            <p>
                                Super restaurant, les burgers sont incroyables et le service est rapide. Je recommande vivement !
                            </p>
                            <h6>Moana Michell</h6>
                            <p>Cliente Fidèle</p>
                        </div>
                        <div class="img-box">
                            <img src="~/images/client1.jpg" alt="" class="box-img">
                        </div>
                    </div>
                </div>
                <div class="item">
                    <div class="box">
                        <div class="detail-box">
                            <p>
                                Les pizzas sont délicieuses. Une excellente adresse pour manger en famille.
                            </p>
                            <h6>Mike Hamell</h6>
                            <p>Client Régulier</p>
                        </div>
                        <div class="img-box">
                            <img src="~/images/client2.jpg" alt="" class="box-img">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>