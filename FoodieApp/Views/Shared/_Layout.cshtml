<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Foodie</title>

    <link rel="stylesheet" type="text/css" href="~/css/bootstrap.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-nice-select/1.1.0/css/nice-select.min.css" />
    <link href="~/css/font-awesome.min.css" rel="stylesheet" />
    <link href="~/css/style.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/responsive.css" rel="stylesheet" />
</head>

<body class="@(ViewData["Title"]?.ToString() == "Home" ? "" : "sub_page")">

    <div class="hero_area">
        <div class="bg-box">
            <img src="~/images/hero-bg-4k.png" alt="Delicious Food Background">
        </div>
        <header class="header_section">
            <div class="container">
                <nav class="navbar navbar-expand-lg custom_nav-container ">

                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                        <span>Foodie</span>
                    </a>

                    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent">
                        <span class=""> </span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav  mx-auto ">
                            <li class="nav-item @(ViewData["Title"]?.ToString() == "Home" ? "active" : "")">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Accueil</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Menu">Menu</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="About">A Propos</a>
                            </li>
                            
                             @if (User.Identity.IsAuthenticated)
                            {
                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-danger font-weight-bold" asp-controller="Products" asp-action="Index" style="white-space: nowrap;">Produits</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-danger font-weight-bold" asp-controller="Categories" asp-action="Index" style="white-space: nowrap;">Catégories</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-danger font-weight-bold" asp-controller="Bookings" asp-action="Index" style="white-space: nowrap;">Réservations</a>
                                    </li>
                                }
                            }
                        </ul>
                        <div class="user_option">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <a asp-controller="Account" asp-action="Profile" class="user_link text-white mr-3" title="Mon Profil">
                                    <i class="fa fa-user" aria-hidden="true"></i>
                                    <span class="d-none d-md-inline-block ml-1">@User.Identity.Name</span>
                                </a>
                                <a class="cart_link text-white mr-3" asp-controller="Cart" asp-action="Index">
                                    <svg version="1.1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" x="0px" y="0px" viewBox="0 0 456.029 456.029" style="enable-background:new 0 0 456.029 456.029;" xml:space="preserve">
                                        <g><g><path d="M345.6,338.862c-29.184,0-53.248,23.552-53.248,53.248c0,29.184,23.552,53.248,53.248,53.248c29.184,0,53.248-23.552,53.248-53.248C398.336,362.926,374.784,338.862,345.6,338.862z" /></g></g>
                                        <g><g><path d="M439.296,84.91c-1.024,0-2.56-0.512-4.096-0.512H112.64l-5.12-34.304C104.448,27.566,84.992,10.67,61.952,10.67H20.48C9.216,10.67,0,19.886,0,31.15c0,11.264,9.216,20.48,20.48,20.48h41.472c2.56,0,4.608,2.048,5.12,4.608l31.744,216.064c4.096,27.136,27.648,47.616,55.296,47.616h212.992c26.624,0,49.664-18.944,55.296-45.056l33.28-166.4C457.728,97.71,450.56,86.958,439.296,84.91z" /></g></g>
                                        <g><g><path d="M215.04,389.55c-1.024-28.16-24.576-50.688-52.736-50.688c-29.696,1.536-52.224,26.112-51.2,55.296c1.024,28.16,24.064,50.688,52.224,50.688h1.024C193.536,443.31,216.576,418.734,215.04,389.55z" /></g></g>
                                    </svg>
                                </a>
                                <a asp-controller="Cart" asp-action="Index" class="order_online">
                                    Commander
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login" class="user_link mr-3">
                                    <i class="fa fa-user" aria-hidden="true"></i>
                                    <span class="ml-2">Connexion</span>
                                </a>
                                <a asp-controller="Account" asp-action="Register" class="order_online">
                                    Inscription
                                </a>
                            }
                        </div>
                    </div>
                </nav>
            </div>
        </header>

        @RenderSection("HeroSection", required: false)
    </div>

    @RenderBody()

    <footer class="footer_section">
        <div class="container">
            <div class="row">
                <div class="col-md-4 footer-col">
                    <div class="footer_contact">
                        <h4>Nous Contacter</h4>
                        <div class="contact_link_box">
                            <a href=""><i class="fa fa-map-marker" aria-hidden="true"></i><span>Adresse</span></a>
                            <a href=""><i class="fa fa-phone" aria-hidden="true"></i><span>+01 1234567890</span></a>
                            <a href=""><i class="fa fa-envelope" aria-hidden="true"></i><span>contact@foodie.com</span></a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 footer-col">
                    <div class="footer_detail">
                        <a href="" class="footer-logo">Foodie</a>
                        <p>Le meilleur restaurant de la ville.</p>
                        <div class="footer_social">
                            <a href=""><i class="fa fa-facebook" aria-hidden="true"></i></a>
                            <a href=""><i class="fa fa-twitter" aria-hidden="true"></i></a>
                            <a href=""><i class="fa fa-instagram" aria-hidden="true"></i></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="footer-info">
                <p>&copy; @DateTime.Now.Year All Rights Reserved By Foodie</p>
            </div>
        </div>
    </footer>

    <script src="~/js/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
    <script src="~/js/bootstrap.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
    <script src="https://unpkg.com/isotope-layout@3.0.4/dist/isotope.pkgd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-nice-select/1.1.0/js/jquery.nice-select.min.js"></script>
    <script src="~/js/custom.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>